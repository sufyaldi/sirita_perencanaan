<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Paperformat standar TOR IAIN (Margen Kiri 3cm, Kanan 2cm) -->
        <record id="paperformat_tor_standar" model="report.paperformat">
            <field name="name">Standar TOR IAIN Parepare</field>
            <field name="default" eval="False"/>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">15</field>
            <field name="margin_bottom">20</field>
            <field name="margin_left">30</field>
            <field name="margin_right">20</field>
            <field name="header_line" eval="False"/>
            <field name="header_spacing">5</field>
            <field name="dpi">90</field>
        </record>

        <record id="action_report_tor" model="ir.actions.report">
            <field name="name">Cetak TOR (KAK)</field>
            <field name="model">sirita.perencanaan.anggaran</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">sirita_perencanaan.report_tor</field>
            <field name="report_file">sirita_perencanaan.report_tor</field>
            <field name="print_report_name">'TOR - %s' % (object.name)</field>
            <field name="binding_model_id" ref="model_sirita_perencanaan_anggaran"/>
            <field name="binding_type">report</field>
            <field name="paperformat_id" ref="paperformat_tor_standar"/>
        </record>
    </data>
</odoo>
